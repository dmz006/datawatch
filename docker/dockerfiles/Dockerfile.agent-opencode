# syntax=docker/dockerfile:1.7
# vim: ft=dockerfile
#
# datawatch agent-opencode — opencode-ai only.
#
# opencode is published as `opencode-ai` (a Node wrapper that picks one
# of 12 per-platform optional dependencies at install time) plus the
# per-platform packages (`opencode-linux-x64`, etc.) that ship the
# actual native binary at `package/bin/opencode`.
#
# We don't need npm OR nodejs. Pull only the platform-specific native
# tarball with curl + tar, copy the ELF binary into the runtime stage.
# This drops nodejs from BOTH the builder and the runtime — was the
# previous Dockerfile's biggest cost (~80 MB nodejs in runtime layer).
#
# BL174 v4.6.0 closure for agent-opencode.

ARG REGISTRY=localhost:5000/datawatch
ARG BASE_TAG=latest
ARG OPENCODE_VERSION=1.4.11

# ── Stage 1: builder — fetch the per-platform native tarball directly
FROM --platform=$BUILDPLATFORM bitnami/minideb:bookworm AS opencodebuilder
ARG TARGETARCH
ARG OPENCODE_VERSION
RUN install_packages curl ca-certificates tar && \
    case "$TARGETARCH" in \
      amd64) PKG="opencode-linux-x64" ;; \
      arm64) PKG="opencode-linux-arm64" ;; \
      *) echo "unsupported TARGETARCH=$TARGETARCH"; exit 1 ;; \
    esac && \
    mkdir -p /out && \
    curl -fsSL "https://registry.npmjs.org/${PKG}/-/${PKG}-${OPENCODE_VERSION}.tgz" \
        -o /tmp/opencode.tgz && \
    tar -xzf /tmp/opencode.tgz -C /out && \
    test -f /out/package/bin/opencode || \
        (echo "native binary missing — per-platform package layout changed?" && \
         find /out -type f -name 'opencode*' -ls && exit 1) && \
    rm /tmp/opencode.tgz

# ── Stage 2: runtime — no node, no npm, no node_modules ────────────────
FROM ${REGISTRY}/agent-base:${BASE_TAG} AS runtime
ARG OPENCODE_VERSION

USER root
COPY --from=opencodebuilder /out/package/bin/opencode /usr/local/bin/opencode
RUN chmod 755 /usr/local/bin/opencode

USER datawatch

LABEL datawatch.variant="agent-opencode" \
      datawatch.agent="opencode-ai" \
      datawatch.tools.opencode=$OPENCODE_VERSION
