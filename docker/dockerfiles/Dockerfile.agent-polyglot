# syntax=docker/dockerfile:1.7
# vim: ft=dockerfile
#
# datawatch agent-polyglot — kitchen sink. Picks up every language layer.
#
# Sequential FROM with COPY --from=… would let us avoid rebuild work, but
# COPY between distinct toolchain-installed images loses the env vars and
# user setup. Cleaner pattern: install everything fresh. Image will be
# large (~2-3GB); intended for users who don't know up-front which toolchain
# their session will need.
#
# Anything updated in the per-language Dockerfiles must be mirrored here.
# `make container-upgrade` keeps both in sync from the same ARG defaults.

ARG REGISTRY=harbor.dmzs.com/datawatch
ARG BASE_TAG=latest
ARG GO_VERSION=1.25.0
ARG GOPLS_VERSION=v0.20.0
ARG GOLANGCI_LINT_VERSION=v2.6.1
ARG DELVE_VERSION=v1.26.1
ARG TYPESCRIPT_VERSION=5.9.4
ARG TSX_VERSION=4.20.6
ARG ESLINT_VERSION=9.39.0
ARG BUN_VERSION=1.3.6
ARG UV_VERSION=0.5.18
ARG POETRY_VERSION=1.8.5
ARG RUFF_VERSION=0.8.4
ARG PYRIGHT_VERSION=1.1.404
ARG RUST_VERSION=1.85.0
ARG JDK_VERSION=21
ARG KOTLIN_VERSION=2.1.10
ARG ANDROID_CMDLINE_TOOLS_VERSION=11076708
ARG GRADLE_VERSION=8.11.1

FROM ${REGISTRY}/agent-base:${BASE_TAG} AS runtime

USER root

# Aggregate build deps for every per-language layer (pulled out of agent-base).
RUN install_packages \
        build-essential pkg-config \
        python3 python3-pip python3-venv pipx \
        libffi-dev libssl-dev

ARG GO_VERSION
ARG GOPLS_VERSION
ARG GOLANGCI_LINT_VERSION
ARG DELVE_VERSION
ARG TYPESCRIPT_VERSION
ARG TSX_VERSION
ARG ESLINT_VERSION
ARG BUN_VERSION
ARG UV_VERSION
ARG POETRY_VERSION
ARG RUFF_VERSION
ARG PYRIGHT_VERSION
ARG RUST_VERSION
ARG JDK_VERSION
ARG KOTLIN_VERSION
ARG ANDROID_CMDLINE_TOOLS_VERSION
ARG GRADLE_VERSION
ARG TARGETARCH

# Go
RUN ARCH="$TARGETARCH"; case "$ARCH" in amd64) A=amd64 ;; arm64) A=arm64 ;; esac && \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${A}.tar.gz" | tar -xz -C /usr/local && \
    ln -s /usr/local/go/bin/go /usr/local/bin/go && \
    ln -s /usr/local/go/bin/gofmt /usr/local/bin/gofmt

# Node tooling extras
RUN npm install -g \
        typescript@${TYPESCRIPT_VERSION} \
        tsx@${TSX_VERSION} \
        eslint@${ESLINT_VERSION} && \
    npm cache clean --force
ENV BUN_INSTALL=/usr/local
RUN curl -fsSL "https://bun.sh/install" | bash -s "bun-v${BUN_VERSION}" && \
    chmod +x /usr/local/bin/bun

# Python tooling
ENV UV_INSTALL_DIR=/usr/local/bin
RUN curl -fsSL https://astral.sh/uv/${UV_VERSION}/install.sh | env UV_NO_MODIFY_PATH=1 sh && \
    PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install poetry==${POETRY_VERSION} && \
    PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install ruff==${RUFF_VERSION} && \
    PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install pyright==${PYRIGHT_VERSION}

# JDK / Kotlin / Gradle / Android cmdline-tools
RUN install_packages openjdk-${JDK_VERSION}-jdk-headless && \
    curl -fsSL "https://github.com/JetBrains/kotlin/releases/download/v${KOTLIN_VERSION}/kotlin-compiler-${KOTLIN_VERSION}.zip" -o /tmp/kotlin.zip && \
    unzip -q /tmp/kotlin.zip -d /opt && rm /tmp/kotlin.zip && \
    ln -s /opt/kotlinc/bin/kotlin /usr/local/bin/kotlin && \
    ln -s /opt/kotlinc/bin/kotlinc /usr/local/bin/kotlinc && \
    curl -fsSL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" -o /tmp/gradle.zip && \
    unzip -q /tmp/gradle.zip -d /opt && rm /tmp/gradle.zip && \
    ln -s /opt/gradle-${GRADLE_VERSION}/bin/gradle /usr/local/bin/gradle

ENV ANDROID_HOME=/opt/android-sdk \
    ANDROID_SDK_ROOT=/opt/android-sdk \
    GRADLE_USER_HOME=/home/datawatch/.gradle \
    PATH=/opt/android-sdk/cmdline-tools/latest/bin:/opt/android-sdk/platform-tools:${PATH}
RUN mkdir -p $ANDROID_HOME/cmdline-tools && \
    curl -fsSL "https://dl.google.com/android/repository/commandlinetools-linux-${ANDROID_CMDLINE_TOOLS_VERSION}_latest.zip" -o /tmp/cmdtools.zip && \
    unzip -q /tmp/cmdtools.zip -d $ANDROID_HOME/cmdline-tools && \
    mv $ANDROID_HOME/cmdline-tools/cmdline-tools $ANDROID_HOME/cmdline-tools/latest && \
    rm /tmp/cmdtools.zip && \
    yes | sdkmanager --licenses >/dev/null 2>&1 || true && \
    chown -R datawatch:datawatch $ANDROID_HOME && \
    mkdir -p $GRADLE_USER_HOME && chown -R datawatch:datawatch $GRADLE_USER_HOME

# Go user-level tools and Rust setup as the unprivileged user.
ENV GOPATH=/home/datawatch/go \
    RUSTUP_HOME=/home/datawatch/.rustup \
    CARGO_HOME=/home/datawatch/.cargo \
    PATH=/home/datawatch/.cargo/bin:/home/datawatch/go/bin:/usr/local/go/bin:${PATH}
RUN mkdir -p /home/datawatch/go && chown -R datawatch:datawatch /home/datawatch/go

USER datawatch
RUN go install golang.org/x/tools/gopls@${GOPLS_VERSION} && \
    go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${GOLANGCI_LINT_VERSION} && \
    go install github.com/go-delve/delve/cmd/dlv@${DELVE_VERSION} && \
    go clean -modcache && \
    curl -fsSL https://sh.rustup.rs | sh -s -- --default-toolchain ${RUST_VERSION} --profile minimal -y && \
    rustup component add clippy rustfmt rust-analyzer rust-src

LABEL datawatch.variant="agent-polyglot" \
      datawatch.lang.go=$GO_VERSION \
      datawatch.lang.node="22" \
      datawatch.lang.python="3.11" \
      datawatch.lang.rust=$RUST_VERSION \
      datawatch.lang.kotlin=$KOTLIN_VERSION \
      datawatch.lang.jdk=$JDK_VERSION
