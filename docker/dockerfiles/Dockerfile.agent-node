# syntax=docker/dockerfile:1.7
# vim: ft=dockerfile
#
# datawatch agent-node — Node/TypeScript worker.
# FROM agent-base (which already has node-${NODE_MAJOR}); adds extra package
# managers + TS tooling that node devs (and claude-code working on them) reach for.

ARG REGISTRY=harbor.dmzs.com/datawatch
ARG BASE_TAG=latest
ARG TYPESCRIPT_VERSION=5.9.4
ARG TSX_VERSION=4.20.6
ARG ESLINT_VERSION=9.39.0
ARG BUN_VERSION=1.3.6

FROM ${REGISTRY}/agent-base:${BASE_TAG} AS runtime

USER root
ARG TYPESCRIPT_VERSION
ARG TSX_VERSION
ARG ESLINT_VERSION
ARG BUN_VERSION
ARG TARGETARCH

# Globally install TypeScript/ESLint/tsx alongside the existing pnpm.
RUN npm install -g \
        typescript@${TYPESCRIPT_VERSION} \
        tsx@${TSX_VERSION} \
        eslint@${ESLINT_VERSION} && \
    npm cache clean --force

# bun (alt runtime + bundler some projects use). Single-binary installer
# from upstream. Detects arch automatically; we set BUN_INSTALL so bun lands
# in /usr/local instead of /root/.bun.
ENV BUN_INSTALL=/usr/local
RUN curl -fsSL "https://bun.sh/install" | bash -s "bun-v${BUN_VERSION}" && \
    chmod +x /usr/local/bin/bun

USER datawatch

LABEL datawatch.variant="agent-node" \
      datawatch.lang.node="22" \
      datawatch.tools.typescript=$TYPESCRIPT_VERSION \
      datawatch.tools.tsx=$TSX_VERSION \
      datawatch.tools.eslint=$ESLINT_VERSION \
      datawatch.tools.bun=$BUN_VERSION
