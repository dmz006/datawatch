# syntax=docker/dockerfile:1.7
# vim: ft=dockerfile
#
# datawatch agent-goose — Block's goose agent only.
#
# Goose ships as a single self-contained Rust binary on GitHub
# Releases (https://github.com/block/goose/releases). No node, no
# python — just curl + tar + drop into /usr/local/bin. Mirrors the
# RTK install layer from agent-base.
#
# The default GOOSE_VERSION below matches the most recent stable
# at the moment of v5.26.42. Bump via:
#   docker build --build-arg GOOSE_VERSION=<x.y.z> -f Dockerfile.agent-goose .
# The CI workflow inherits the default; operators tagging a release
# pick up whatever the Dockerfile pins.

ARG REGISTRY=localhost:5000/datawatch
ARG BASE_TAG=latest
ARG GOOSE_VERSION=1.32.0

FROM ${REGISTRY}/agent-base:${BASE_TAG} AS runtime
ARG GOOSE_VERSION
ARG TARGETARCH

USER root
RUN ARCH="$TARGETARCH"; case "$ARCH" in \
        amd64) GOOSE_ARCH="x86_64-unknown-linux-gnu" ;; \
        arm64) GOOSE_ARCH="aarch64-unknown-linux-gnu" ;; \
        *) echo "unsupported arch $ARCH"; exit 1 ;; \
    esac && \
    curl -fsSL "https://github.com/block/goose/releases/download/v${GOOSE_VERSION}/goose-${GOOSE_ARCH}.tar.bz2" \
        -o /tmp/goose.tar.bz2 && \
    install_packages bzip2 && \
    # Tarball entry is "./goose" — extract everything (only one
    # file in the archive) so the bare-name positional doesn't
    # miss the leading "./" prefix.
    tar -xjf /tmp/goose.tar.bz2 -C /usr/local/bin/ && \
    chmod +x /usr/local/bin/goose && \
    test -x /usr/local/bin/goose || \
        (echo "goose binary missing after extract" && ls -la /usr/local/bin/ && exit 1) && \
    rm /tmp/goose.tar.bz2 && \
    # Aggressive cleanup — bzip2's apt artifacts + any stale caches
    rm -rf /var/cache/apt/* /tmp/* /root/.cache

USER datawatch

LABEL datawatch.variant="agent-goose" \
      datawatch.agent="goose" \
      datawatch.tools.goose=$GOOSE_VERSION
