# syntax=docker/dockerfile:1.7
# vim: ft=dockerfile
#
# datawatch agent-python — Python worker.
# FROM agent-base (already has python3 + pipx); adds modern Python tooling
# (uv, poetry, ruff, pyright) that claude-code now defaults to.

ARG REGISTRY=harbor.dmzs.com/datawatch
ARG BASE_TAG=latest
ARG UV_VERSION=0.5.18
ARG POETRY_VERSION=1.8.5
ARG RUFF_VERSION=0.8.4
ARG PYRIGHT_VERSION=1.1.404
# LLM CLIs that live with python rather than agent-base (size-critical).
ARG AIDER_VERSION=0.86.0
ARG GEMINI_CLI_VERSION=0.38.2

FROM ${REGISTRY}/agent-base:${BASE_TAG} AS runtime

USER root
ARG UV_VERSION
ARG POETRY_VERSION
ARG RUFF_VERSION
ARG PYRIGHT_VERSION
ARG AIDER_VERSION
ARG GEMINI_CLI_VERSION
ARG TARGETARCH

# Full python toolchain (agent-base has only python3-minimal).
# build-essential + dev headers needed for many pip packages with C extensions.
RUN install_packages \
        python3 python3-pip python3-venv pipx \
        build-essential pkg-config \
        libffi-dev libssl-dev

# uv (Astral's fast pip/pipenv replacement) — single binary install
ENV UV_INSTALL_DIR=/usr/local/bin
RUN curl -fsSL https://astral.sh/uv/${UV_VERSION}/install.sh | env UV_NO_MODIFY_PATH=1 sh

# Other tools + aider via pipx so they're isolated and clean to upgrade.
# aider lives here (not agent-base) because its dep tree is ~960MB and
# that's a painful tax on every variant that doesn't actually use it.
RUN PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install poetry==${POETRY_VERSION} && \
    PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install ruff==${RUFF_VERSION} && \
    PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install pyright==${PYRIGHT_VERSION} && \
    PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install aider-chat==${AIDER_VERSION} && \
    rm -rf /root/.cache/pip /opt/pipx/.cache

# gemini-cli (npm) co-located with python tooling for now — also sized
# out of agent-base. Move to agent-base later if usage broadens.
RUN npm install -g --omit=optional --no-audit --no-fund \
        @google/gemini-cli@${GEMINI_CLI_VERSION} && \
    npm cache clean --force && \
    rm -rf /root/.npm

USER datawatch

LABEL datawatch.variant="agent-python" \
      datawatch.lang.python="3.11" \
      datawatch.tools.uv=$UV_VERSION \
      datawatch.tools.poetry=$POETRY_VERSION \
      datawatch.tools.ruff=$RUFF_VERSION \
      datawatch.tools.pyright=$PYRIGHT_VERSION \
      datawatch.tools.aider=$AIDER_VERSION \
      datawatch.tools.gemini-cli=$GEMINI_CLI_VERSION
