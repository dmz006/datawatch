# syntax=docker/dockerfile:1.7
# vim: ft=dockerfile
#
# datawatch agent-base — minimal foundation. ONLY contains the things
# every agent and every language image needs:
#   * datawatch binary
#   * tmux + git + gh + ssh + ca-certs + tini
#   * unix tooling claude shells out to (ripgrep, jq, fd, less, ...)
#
# Does NOT contain:
#   * any LLM agent (claude, opencode, aider, gemini) — those live in agent-* images
#   * any language toolchain (Go/Node/Python/Rust/Kotlin) — those live in lang-* images
#   * Node.js or Python — only in the agent/lang images that need them
#   * /usr/include, /usr/share/{doc,man,locale,info} — stripped after install
#
# Composition model: deploy one agent-* image and one lang-* image as
# two containers in the same Pod (or docker-compose service group),
# sharing /workspace as a volume. The K8s driver in F10 sprint 4 will
# auto-build the manifest from a Project Profile's {agent, language}
# tuple.
#
# Target size: ~250-300MB.

ARG GO_VERSION=1.25
ARG MINIDEB_TAG=bookworm
ARG RTK_VERSION=0.37.0

# ── Stage 1: Go builder for the datawatch binary ────────────────────────
FROM --platform=$BUILDPLATFORM golang:${GO_VERSION}-${MINIDEB_TAG} AS dwbuilder
ARG TARGETOS
ARG TARGETARCH
ARG VERSION=dev
WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download
COPY . .
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build \
      -trimpath \
      -ldflags="-s -w -X main.Version=${VERSION}" \
      -o /out/datawatch \
      ./cmd/datawatch

# ── Stage 2: runtime ────────────────────────────────────────────────────
FROM bitnami/minideb:${MINIDEB_TAG} AS runtime
ARG RTK_VERSION
ARG TARGETARCH

# Apt — every package an agent or language image will eventually depend on.
# bitnami's install_packages cleans /var/lib/apt/lists/ for us.
RUN install_packages \
        # process supervision
        tini \
        # session multiplexing
        tmux \
        # tls + dns
        ca-certificates openssl \
        # vcs
        git git-lfs openssh-client gnupg \
        # core unix
        bash coreutils findutils grep sed gawk less \
        # network
        curl wget rsync \
        # claude's heavy hitters
        ripgrep fd-find jq \
        # archives
        xz-utils zip unzip \
        # operator essentials only
        procps file tree which sudo && \
    # debian's fd-find binary is /usr/bin/fdfind; symlink to `fd` for
    # compatibility with claude-code's hardcoded `fd` invocations.
    ln -sf /usr/bin/fdfind /usr/local/bin/fd

# ── Layer 2: GitHub CLI (apt repo) ──────────────────────────────────────
RUN install_packages curl gnupg && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    install_packages gh

# ── Layer 3: rtk binary (token-saving CLI used by every agent) ─────────
RUN ARCH="$TARGETARCH"; case "$ARCH" in \
        amd64) RTK_ARCH="x86_64-unknown-linux-musl" ;; \
        arm64) RTK_ARCH="aarch64-unknown-linux-gnu" ;; \
        *) echo "unsupported arch $ARCH"; exit 1 ;; \
    esac && \
    curl -fsSL "https://github.com/rtk-ai/rtk/releases/download/v${RTK_VERSION}/rtk-${RTK_ARCH}.tar.gz" \
        -o /tmp/rtk.tar.gz && \
    tar -xzf /tmp/rtk.tar.gz -C /usr/local/bin/ rtk && \
    chmod +x /usr/local/bin/rtk && \
    rm /tmp/rtk.tar.gz

# ── Layer 4: aggressive size cleanup ────────────────────────────────────
# Strip everything an agent at runtime never reads:
#   * docs/man — operator can read on the host
#   * locales — keep only en_US (most agents are English)
#   * /usr/include — C headers belong in lang-* images, not here
#   * cache + tmp leftovers
#
# This pass alone removes ~200MB on agent-base and on every downstream
# variant that doesn't restore them.
RUN \
    # Wipe contents but KEEP the directory trees — apt post-install scripts
    # for some downstream packages (openjdk-17-* in particular) try to
    # write into /usr/share/man/manN. If the dir is gone, dpkg fails.
    find /usr/share/doc /usr/share/doc-base /usr/share/man /usr/share/info \
         /usr/share/groff /usr/share/lintian /usr/share/linda \
         /usr/share/python-wheels \
         -mindepth 1 -type f -delete 2>/dev/null || true && \
    # /usr/include is safe to delete — only language images need C headers
    rm -rf /usr/include /var/cache/apt/* /var/log/* /tmp/* /root/.cache && \
    # Keep only english locales — saves ~22MB
    find /usr/share/locale -mindepth 1 -maxdepth 1 -type d \
        ! -name 'en' ! -name 'en_US' ! -name 'en_US.UTF-8' \
        -exec rm -rf {} +

# ── Layer 5: non-root user, dirs, datawatch binary ──────────────────────
RUN groupadd -r -g 10001 datawatch && \
    useradd -r -u 10001 -g datawatch -m -d /home/datawatch -s /bin/bash datawatch && \
    mkdir -p /data /workspace && \
    chown -R datawatch:datawatch /data /workspace /home/datawatch

COPY --from=dwbuilder /out/datawatch /usr/local/bin/datawatch
COPY docker/entrypoint.sh /usr/local/bin/datawatch-entrypoint
RUN chmod +x /usr/local/bin/datawatch-entrypoint

USER datawatch
WORKDIR /data
ENV DATAWATCH_DATA_DIR=/data \
    DATAWATCH_WORKSPACE_ROOT=/workspace \
    PATH="/home/datawatch/.local/bin:${PATH}"

EXPOSE 8080 8443 8081

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/datawatch-entrypoint"]
CMD ["start", "--foreground"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD ["datawatch", "health"]

LABEL org.opencontainers.image.title="datawatch agent-base" \
      org.opencontainers.image.description="Minimal foundation — datawatch + tmux + git + gh + rtk + unix tooling. No agents, no language toolchains. Compose with one agent-* + one lang-* image per Pod." \
      org.opencontainers.image.source="https://github.com/dmz006/datawatch" \
      org.opencontainers.image.licenses="MIT" \
      datawatch.variant="agent-base" \
      datawatch.tools.rtk=$RTK_VERSION
