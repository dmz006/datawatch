# syntax=docker/dockerfile:1.7
# vim: ft=dockerfile
#
# datawatch agent-aider — aider-chat only.
# Heavy due to litellm's 100+ deps; ~1.2GB irreducibly.
# pipx isolates aider's deps from the system Python (PEP 668).

ARG REGISTRY=harbor.dmzs.com/datawatch
ARG BASE_TAG=latest
ARG AIDER_VERSION=0.86.0

FROM ${REGISTRY}/agent-base:${BASE_TAG} AS runtime
ARG AIDER_VERSION

USER root
# Full python (not just minimal) is needed for many of aider's deps.
# build-essential lets pip compile native wheels when prebuilt aren't avail.
RUN install_packages \
        python3 python3-pip python3-venv pipx \
        build-essential pkg-config libffi-dev libssl-dev && \
    PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin pipx install aider-chat==${AIDER_VERSION} && \
    # Aggressive cleanup — pipx leaves install artifacts and pip caches
    rm -rf /root/.cache/pip /opt/pipx/.cache /home/datawatch/.cache \
           /var/cache/apt/* \
           /usr/share/doc /usr/share/man /usr/include \
           /tmp/* /root/.npm

USER datawatch

LABEL datawatch.variant="agent-aider" \
      datawatch.agent="aider-chat" \
      datawatch.tools.aider=$AIDER_VERSION
