# Datawatch container build configuration.
# Copy this to `.env.build` and edit. .env.build is gitignored.
#
# Used by `make container`, `make container-load`, `make container-tarball`.

# Registry to push to. Format: <host>/<project>
# Harbor requires the project to exist before push; "library" is the default
# project that ships with every Harbor install.
#   harbor (library): REGISTRY=harbor.dmzs.com/library
#   harbor (custom):  REGISTRY=harbor.dmzs.com/datawatch  (create project first)
#   local fallback:   REGISTRY=192.168.1.51:5000/library  (run `make registry-up`)
#   ghcr (later):     REGISTRY=ghcr.io/dmz006
REGISTRY=harbor.dmzs.com/library

# Platforms to build for. Multi-arch requires PUSH=true (docker --load
# does not accept multiple platforms in a single build).
PLATFORMS=linux/amd64,linux/arm64

# Push to REGISTRY after build. Set to false for local-only dev builds.
PUSH=true

# Override the tag suffix (defaults to the Version in main.go).
# Useful for branch builds: CONTAINER_TAG=pr42-$(git rev-parse --short HEAD)
# CONTAINER_TAG=
