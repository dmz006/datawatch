# Datawatch container build configuration.
# Copy this to `.env.build` and edit. .env.build is gitignored.
#
# Used by `make container*` targets — image taxonomy:
#   {REGISTRY}/agent-base:{TAG}     common runtime, every variant FROMs this
#   {REGISTRY}/agent-go:{TAG}       per-language workers
#   {REGISTRY}/agent-node:{TAG}
#   {REGISTRY}/agent-python:{TAG}
#   {REGISTRY}/agent-rust:{TAG}
#   {REGISTRY}/agent-kotlin:{TAG}
#   {REGISTRY}/agent-polyglot:{TAG} kitchen sink
#   {REGISTRY}/parent-full:{TAG}    control-plane (polyglot + signal-cli)

# Registry to push to. Format: <host>/<project> — REQUIRED.
# The default below points at the local-dev fallback registry that
# `make registry-up` brings up; replace with whatever your team uses.
# Examples:
#   ghcr (recommended for OSS): REGISTRY=ghcr.io/your-org/datawatch
#   harbor (org project):       REGISTRY=harbor.example.com/datawatch
#   harbor (library project):   REGISTRY=harbor.example.com/library
#   gitlab container registry:  REGISTRY=registry.gitlab.com/your-group/datawatch
#   AWS ECR:                    REGISTRY=<acct>.dkr.ecr.<region>.amazonaws.com/datawatch
#   local-dev fallback:         REGISTRY=localhost:5000/datawatch  (`make registry-up`)
REGISTRY=localhost:5000/datawatch

# Platforms to build for. Multi-arch requires PUSH=true (docker --load
# does not accept multiple platforms in a single build).
PLATFORMS=linux/amd64,linux/arm64

# Push to REGISTRY after build. Set to false for local-only dev builds.
# Local-dev with localhost:5000/datawatch typically uses PUSH=false.
PUSH=false

# Subset of language variants to build. Defaults to all five; trim for
# faster iteration: AGENT_VARIANTS="go kotlin"
# AGENT_VARIANTS=go node python rust kotlin

# Override the tag suffix (defaults to v$(VERSION) from main.go).
# Useful for branch builds: CONTAINER_TAG=pr42-$(git rev-parse --short HEAD)
# CONTAINER_TAG=
