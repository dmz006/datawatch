# syntax=docker/dockerfile:1.7

# Datawatch slim — ephemeral agent worker image.
#
# Goals: smallest possible image that still runs a full datawatch daemon
# capable of hosting AI-coding sessions over tmux. NO signal-cli, NO Java,
# NO node — those are reserved for the "full" image. Memory + HTTP + MCP
# all work; messaging backends are simply disabled in config.
#
# Build:
#   docker buildx build -f Dockerfile.slim --platform linux/amd64,linux/arm64 \
#       --build-arg VERSION=$(git describe --tags --always) \
#       -t harbor.dmzs.com/datawatch/datawatch:slim-vX.Y.Z .

ARG GO_VERSION=1.25
ARG DEBIAN_VERSION=bookworm

# ── Stage 1: builder ─────────────────────────────────────────────────────
FROM --platform=$BUILDPLATFORM golang:${GO_VERSION}-${DEBIAN_VERSION} AS builder

ARG TARGETOS
ARG TARGETARCH
ARG VERSION=dev

WORKDIR /src

# Cache go.mod separately for layer reuse
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

COPY . .

# Inject version at build time. CGO_ENABLED=0 keeps the binary fully static
# so it runs in distroless/scratch derivatives if we ever need them.
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build \
      -trimpath \
      -ldflags="-s -w -X main.Version=${VERSION}" \
      -o /out/datawatch \
      ./cmd/datawatch

# ── Stage 2: runtime ─────────────────────────────────────────────────────
# debian:slim because tmux is *required* (datawatch sessions live in tmux)
# and distroless has no tmux. This is still a small image (~85MB).
FROM debian:${DEBIAN_VERSION}-slim AS runtime

# Runtime deps:
#   tmux        — session multiplexing (mandatory)
#   ca-certificates — TLS for outbound API calls (memory, GitHub, gh CLI)
#   git         — F10 Sprint 5 will clone repos here; cheap to include now
#   tini        — PID 1 reaper so zombie tmux/claude/etc. processes don't
#                 accumulate in long-lived agent containers
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        tmux \
        ca-certificates \
        git \
        tini \
    && rm -rf /var/lib/apt/lists/*

# Non-root user. UID/GID 10001 chosen to avoid clashing with any host UID
# when /workspace is mounted from NFS or a PVC.
RUN groupadd -r -g 10001 datawatch \
    && useradd -r -u 10001 -g datawatch -m -d /home/datawatch -s /bin/bash datawatch

# Datawatch directories
#   /data       persistent state (config, sessions.json, memory.db, logs)
#   /workspace  base for session project_dirs (PVC / NFS / bind mount)
RUN mkdir -p /data /workspace \
    && chown -R datawatch:datawatch /data /workspace

COPY --from=builder /out/datawatch /usr/local/bin/datawatch
COPY docker/entrypoint.sh /usr/local/bin/datawatch-entrypoint
RUN chmod +x /usr/local/bin/datawatch-entrypoint

USER datawatch
WORKDIR /data

# Environment defaults the entrypoint reads
ENV DATAWATCH_DATA_DIR=/data \
    DATAWATCH_WORKSPACE_ROOT=/workspace \
    DATAWATCH_SLIM=1

EXPOSE 8080 8443 8081

# tini handles signals and zombie reaping. The entrypoint script materializes
# a minimal config from env if /data/config.yaml is absent (zero-config boot
# for ephemeral agents — Sprint 3 wires the bootstrap callback on top of this).
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/datawatch-entrypoint"]
CMD ["start", "--foreground"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --quiet --spider http://localhost:8080/healthz || exit 1

LABEL org.opencontainers.image.title="datawatch (slim)" \
      org.opencontainers.image.description="Ephemeral AI-agent worker — full daemon, no signal/java/node" \
      org.opencontainers.image.source="https://github.com/dmz006/datawatch" \
      org.opencontainers.image.licenses="MIT" \
      datawatch.variant="slim"
